{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Exact permissions for the local launcher WebView",
  "windows": ["main"],
  "permissions": [
    "allow-search-apps",
    "allow-search-files",
    "allow-execute-result",
    "allow-load-settings",
    "allow-save-settings",
    "allow-rescan-apps",
    "allow-export-validation-data",
    "allow-clear-validation-data",
    "allow-hide-launcher",
    "core:event:allow-listen",
    "core:event:allow-unlisten"
  ]
}
